# ──────────────────────────────────────────────
# 311 Pulse — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────

# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# LLM — primary: Nemotron via NIM (OpenAI-compatible)
# Set LLM_PROVIDER=fallback to use the fallback provider instead
LLM_PROVIDER=nim
NIM_BASE_URL=http://localhost:8000/v1
NIM_API_KEY=
NIM_MODEL=nvidia/nemotron-70b-instruct

# LLM — fallback: any OpenAI-compatible provider
FALLBACK_BASE_URL=https://api.openai.com/v1
FALLBACK_API_KEY=
FALLBACK_MODEL=gpt-4o-mini

# CopilotKit
NEXT_PUBLIC_COPILOTKIT_URL=/api/copilotkit

# Mastra agent server (optional — used for AG-UI / @ag-ui/mastra integration)
MASTRA_URL=http://localhost:4111

# Data pipeline engine: pandas | polars | duckdb | rapids
# Use "rapids" only on the DGX Spark with RAPIDS extras installed.
PIPELINE_ENGINE=pandas
